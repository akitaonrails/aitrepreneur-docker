# Copy to .env and adjust. The .env file is gitignored (it may hold tokens).

# Git ref (branch, tag, or commit sha) of ostris/ai-toolkit to build.
# Pin a commit sha for reproducible builds; `main` tracks upstream.
AI_TOOLKIT_REF=main

# PyTorch CUDA wheel stream: cu128 for RTX 50xx / Blackwell, cu126 for older GPUs.
CUDA_STREAM=cu128

# Host port for the web UI.
UI_PORT=8675

# Where downloaded base models land (Hugging Face cache). Keep on the NAS —
# checkpoints are tens of GB each.
HF_CACHE_DIR=/mnt/gigachad/comfyui/models/hf-cache

# Existing ComfyUI models tree, mounted read-only at /comfyui-models inside
# the container so training configs can reference local checkpoints.
COMFYUI_MODELS_DIR=/mnt/gigachad/comfyui/models

# Hugging Face token, needed to download gated models (FLUX, Krea, etc.).
# https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional password for the web UI. Empty = no login required.
AI_TOOLKIT_AUTH=

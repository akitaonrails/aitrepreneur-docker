# Copy to .env and adjust. The .env file is gitignored (it may hold tokens).

# ───────── Version pins (see docs/UPGRADING.md) ─────────

# Git ref (branch, tag, or commit sha) of ostris/ai-toolkit to build.
AI_TOOLKIT_REF=main

# ComfyUI ref per app. krea2/ideogram need a recent ComfyUI (native Krea 2 /
# Ideogram 4 support); ltx is pinned to the version its workflow was built for.
COMFY_REF_KREA2=master
COMFY_REF_IDEOGRAM=master
COMFY_REF_LTX=v0.21.1

# PyTorch CUDA wheel stream for ai-toolkit: cu128 for RTX 50xx / Blackwell.
# (The ComfyUI apps pin their torch stack in comfyui/Dockerfile ARGs.)
CUDA_STREAM=cu128

# ───────── Ports ─────────

AI_TOOLKIT_PORT=8675
KREA2_PORT=8188
IDEOGRAM_PORT=8189
LTX_PORT=8190

# ───────── Storage ─────────

# Where downloaded base models land. Keep on the NAS — tens of GB each.
# ai-toolkit downloads into HF_CACHE_DIR (HF cache layout); the ComfyUI apps
# download straight into COMFYUI_MODELS_DIR (ComfyUI layout, shared with your
# existing ComfyUI models — files already present are never re-downloaded).
COMFYUI_MODELS_DIR=/mnt/gigachad/comfyui/models
HF_CACHE_DIR=/mnt/gigachad/comfyui/models/hf-cache

# Secondary caches: torch.hub and other library downloads (CLIP, LPIPS and
# similar aux models). Shared by all services.
AUX_CACHE_DIR=/mnt/gigachad/comfyui/models/aitk-cache

# Ideogram Ultra workflow template images (extracted from
# docs/reference/IDEOGRAM-TEMPLATES.zip; shown under input/templates in the UI).
IDEOGRAM_TEMPLATES_DIR=/mnt/gigachad/comfyui/ideogram-templates

# ai-toolkit training datasets and results. Local by default (fast, and LoRAs
# are small); uncomment to move to the NAS.
#DATASETS_DIR=/mnt/gigachad/comfyui/ai-toolkit/datasets
#OUTPUTS_DIR=/mnt/gigachad/comfyui/ai-toolkit/outputs

# ───────── Secrets ─────────

# Hugging Face token, needed to download gated models.
# https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional password for the ai-toolkit web UI. Empty = no login required.
AI_TOOLKIT_AUTH=
